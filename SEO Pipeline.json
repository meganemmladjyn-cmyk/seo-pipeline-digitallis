        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 500,\n  \"system\": \"Tu es un évaluateur SEO. Retourne UNIQUEMENT un JSON valide sans markdown. Format : {\\\"score\\\": number, \\\"seo\\\": number, \\\"lisibilite\\\": number, \\\"pertinence\\\": number, \\\"structure\\\": number, \\\"feedback\\\": string}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Évalue cet article pour le mot-clé '{{ $json.query || $json['﻿query'] }}'. Titre : {{ $json.titre }}. Mots-clés : {{ $json.mots_cles }}. Retourne uniquement le JSON.\"\n    }\n  ]\n}",
