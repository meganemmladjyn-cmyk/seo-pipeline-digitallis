        "jsCode": "const response = $input.first().json;\nconst raw = response.content[0].text;\nconst clean = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\nconst evaluation = JSON.parse(clean);\n\nconst article = $('Set').first().json;\nconst sonnet = $('Code in JavaScript').first().json;\n\nreturn [{\n  json: {\n    query: sonnet.query || article.query || \"\",\n    titre: sonnet.titre || article.titre || \"\",\n    meta_description: sonnet.meta_description || article.meta_description || \"\",\n    corps: sonnet.corps || article.corps || \"\",\n    mots_cles: sonnet.mots_cles || article.mots_cles || \"\",\n    score: evaluation.score || 0,\n    seo: evaluation.seo || 0,\n    lisibilite: evaluation.lisibilite || 0,\n    pertinence: evaluation.pertinence || 0,\n    structure: evaluation.structure || 0,\n    feedback: evaluation.feedback || \"\",\n    date_generation: new Date().toISOString()\n  }\n}];"
      },
