      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text;\nconst clean = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\nconst article = JSON.parse(clean);\n\nconst query = $('Loop Over Items').first().json.query || \"\";\n\nreturn [{\n  json: {\n    query: query,\n    titre: article.titre || \"\",\n    meta_description: article.meta_description || \"\",\n    corps: article.corps || \"\",\n    mots_cles: (article.mots_cles_utilises || []).join(', ')\n  }\n}];"
      },
